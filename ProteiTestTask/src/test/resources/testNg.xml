<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Authorization + Registration Suite" verbose="1" parallel="none">

    <test name="Authorization Tests">
        <classes>
            <class name="TestTools.TestCases.Authorization.AuthorizationTestsPositive"/>
            <class name="TestTools.TestCases.Authorization.AuthorizationTestsNegative"/>
        </classes>
    </test>

    <test name="Registration Tests">
        <classes>
            <class name="TestTools.TestCases.Registration.RegistrationTestsPositive"/>
            <class name="TestTools.TestCases.Registration.RegistrationTestsNegative"/>
        </classes>
    </test>

</suite>